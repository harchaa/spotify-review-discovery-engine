# Pick one provider. LLM_PROVIDER defaults to "gemini" if unset.
LLM_PROVIDER=gemini

# Required if LLM_PROVIDER=gemini (default). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Required if LLM_PROVIDER=groq. Get one at https://console.groq.com/keys
# Used as a fallback when a given Gemini project/key is capped well below
# Gemini's documented free-tier limit (see README "LLM provider" section).
GROQ_API_KEY=your_groq_api_key_here
